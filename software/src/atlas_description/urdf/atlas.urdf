<?xml version="1.0"?>
<robot name="atlas_rover">

  <!-- Base chassis -->
  <link name="base_link">

    <visual>
      <geometry>
        <box size="0.6 0.4 0.2"/>
      </geometry>

      <origin xyz="0 0 0"/>
    </visual>

    <collision>
      <geometry>
        <box size="0.6 0.4 0.2"/>
      </geometry>
    </collision>

    <inertial>
      <mass value="5"/>
      <inertia
        ixx="0.1"
        ixy="0"
        ixz="0"
        iyy="0.1"
        iyz="0"
        izz="0.1"/>
    </inertial>

  </link>


  <!-- Left wheel -->
  <link name="left_wheel">

    <visual>
      <geometry>
        <cylinder radius="0.1" length="0.05"/>
      </geometry>

      <origin rpy="1.5708 0 0"/>
    </visual>

  </link>


  <!-- Right wheel -->
  <link name="right_wheel">

    <visual>
      <geometry>
        <cylinder radius="0.1" length="0.05"/>
      </geometry>

      <origin rpy="1.5708 0 0"/>
    </visual>

  </link>


  <!-- Left wheel joint -->
  <joint name="left_wheel_joint" type="continuous">

    <parent link="base_link"/>
    <child link="left_wheel"/>

    <origin xyz="0 0.25 -0.1"/>

    <axis xyz="0 1 0"/>

  </joint>


  <!-- Right wheel joint -->
  <joint name="right_wheel_joint" type="continuous">

    <parent link="base_link"/>
    <child link="right_wheel"/>

    <origin xyz="0 -0.25 -0.1"/>

    <axis xyz="0 1 0"/>

  </joint>


</robot>